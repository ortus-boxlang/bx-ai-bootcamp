// service-example.bxs
// Using aiService() to create reusable provider connections
// Run with: boxlang service-example.bxs

// Create services for different providers
openaiService = aiService( "openai" )
ollamaService = aiService( "ollama" )

// Prepare a question
question = aiMessage().user( "What is BoxLang in one sentence?" )

// Create request
request = aiChatRequest( question )

// Invoke the service
responseAI = openaiService.chat( request )
responseOLLAMA = ollamaService.chat( request )

println( "OpenAI says:" )
println( responseAI )

println( "Ollama says:" )
println( responseOLLAMA )
